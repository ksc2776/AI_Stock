# 환경 변수 설정 파일
# 실제 사용 시 .env 파일을 생성하고 값을 입력하세요

# Node 환경 (development, production, staging)
NODE_ENV=production

# 서버 포트
PORT=8080

# 로깅 레벨 (error, warn, info, debug)
LOG_LEVEL=info

# 데이터베이스 (필요시)
# DATABASE_URL=

# API 키 (필요시)
# API_KEY=

# CORS 설정 (스마트폰 앱 접근용)
CORS_ORIGIN=*

# 디버그 모드
DEBUG=false

{
  "name": "eqv-quant-agent",
  "version": "1.0.0",
  "description": "EQV 실시간 수급·매매 분석 퀀트 에이전트",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.eqv.quantagent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "iconv-lite": "^0.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "electron": "^36.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.3.0"
  }
}
